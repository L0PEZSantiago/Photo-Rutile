{% extends 'base.html.twig' %}

{% block importmap %}
    {{ parent() }}
    {{ importmap('theme') }}
{% endblock %}

{% block title %}Thèmes
{% endblock %}

{% block main %}
	<h1>Thèmes</h1>

	<div class="container">
		{% for theme in themes %}
			<div class="row">
				<div class="theme-infos">
					<p>{{ theme.name }}</p>
					<p>{{ theme.isActive ? 'Actif' : 'Inactif' }}</p>
				</div>
				<div class="admin-actions">
					<a href="{{ path('app.theme.edit', {'id': theme.id}) }}">{{ iconsCollection.pen|raw }}Modifier</a>
					{{ include('backOffice/theme/_delete_form.html.twig', {'theme': theme}) }}
				</div>
			</div>
		{% endfor %}
	</div>

	<a href="{{ path('app.theme.new') }}">Créer un nouveau thème</a>
{% endblock %}
