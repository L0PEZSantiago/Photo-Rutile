			</div>
		<a href={{ path('app.creation.index') }} class="btn-primary">Voir les créations</a>
		</div>
	</section>

	<section class="how-buy">
	<div class="container">
		<div class="section-title">
			<h2>Comment acheter ?</h2>
			<p>Les achats se font directement sur place à l'atelier. Livraison possible à proximité.</p>
		</div>
	<div class="how-buy-cards">
				<div class="how-buy-card">
					<div class="card-icon map">
						{{ iconsCollection.map|raw }}
					</div>
					<h3>Sur place</h3>
					<p>Venez découvrir les créations directement à l'atelier et repartez avec votre pièce.</p>
				</div>
				<div class="how-buy-card">
					<div class="card-icon truck">
						{{ iconsCollection.truck|raw }}
					</div>
					<h3>Livraison locale</h3>
					<p>Livraison possible si vous n'habitez pas trop loin. Contactez-nous pour en discuter.</p>
				</div>
				<div class="how-buy-card">
					<div class="card-icon phone">
						{{ iconsCollection.phone|raw }}
					</div>
					<h3>Nous contacter</h3>
					<p>Pour toute question ou commande spéciale, n'hésitez pas à nous appeler.</p>
				</div>
			</div>
	</div>
	</section>
{% endblock %}
