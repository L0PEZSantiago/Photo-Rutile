{% extends 'base.html.twig' %}

{% block title %}Creation{% endblock %}

{% block main %}
    <h1>Creation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ creation.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ creation.title }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ creation.slug }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ creation.description }}</td>
            </tr>
            <tr>
                <th>ImageFilename</th>
                <td>{{ creation.imageFilename }}</td>    <img src="{{ asset('uploads/creations/' ~ creation.imageFilename) }}" alt="{{ creation.title }}">
                <td>
                    <img src="{{ asset('uploads/creations/' ~ creation.imageFilename) }}" alt="{{ creation.title }}">
                </td>
            </tr>
            <tr>
                <th>IsPublished</th>
                <td>{{ creation.isPublished ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ creation.createdAt ? creation.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ creation.updatedAt ? creation.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app.creation.index') }}">back to list</a>

    <a href="{{ path('app.creation.edit', {'id': creation.id}) }}">edit</a>

    {{ include('frontOffice/creations/_delete_form.html.twig') }}
{% endblock %}
